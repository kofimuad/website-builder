@page "/manage/{SiteId:guid}/edit"
@using WebsiteBuilder.Core.Generation
@using WebsiteBuilder.Core.SiteModel
@using WebsiteBuilder.Web.Management
@rendermode InteractiveServer
@implements IDisposable
@inject SiteManagementService Management
@inject IServiceProvider Services
@inject IAssistantRateLimiter RateLimiter

<PageTitle>Edit your website</PageTitle>

@if (_notFound)
{
    <div class="shell"><div class="empty"><h1>We couldn't find that website</h1></div></div>
}
else if (_site is null)
{
    <div class="shell"><div class="empty"><p>Loading…</p></div></div>
}
else
{
    <div class="bar">
        <span class="status @(_dirty ? "busy" : "")">
            <svg class="status-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            @_status
        </span>
        <div class="bar-actions">
            <button type="button" class="btn" @onclick="() => _showThemes = !_showThemes">Look</button>
            <button type="button" class="btn" @onclick="TryAnotherLook">Try another look</button>
            <button type="button" class="btn" @onclick="OpenPreview">Preview</button>
            <a class="btn" href="/manage/@SiteId/profile">Business details</a>
            <button type="button" class="btn primary" @onclick="Publish" disabled="@_publishing">Publish</button>
        </div>
    </div>

    @if (_showThemes)
    {
        <div class="themes">
            <div class="themes-head">
                <span>Choose a look — your words stay the same</span>
                <button type="button" @onclick="() => _showThemes = false">Close</button>
            </div>
            <div class="themes-grid">
                @foreach (var preset in ThemePresetCatalog.Presets)
                {
                    <button type="button" class="swatch @(IsCurrent(preset) ? "on" : "")" @onclick="() => ApplyTheme(preset)">
                        <span class="chips">
                            <i style="background:@preset.Theme.Palette.Primary"></i>
                            <i style="background:@preset.Theme.Palette.Accent"></i>
                            <i style="background:@preset.Theme.Palette.Surface"></i>
                        </span>
                        <span class="swatch-label">@preset.Label</span>
                    </button>
                }
            </div>
        </div>
    }

    @if (_showPreview)
    {
        <div class="preview-overlay">
            <div class="preview-bar">
                <div class="widths" role="group" aria-label="Preview width">
                    <button type="button" class="@(_phoneWidth ? "" : "on")" @onclick="() => _phoneWidth = false">Desktop</button>
                    <button type="button" class="@(_phoneWidth ? "on" : "")" @onclick="() => _phoneWidth = true">Phone</button>
                </div>
                <div class="preview-bar-actions">
                    <button type="button" class="btn" @onclick="RefreshPreview">Refresh</button>
                    <button type="button" class="btn" @onclick="() => _showPreview = false">Close</button>
                </div>
            </div>
            <div class="preview-stage">
                <div class="preview-frame @(_phoneWidth ? "phone" : "desktop")">
                    <iframe title="Preview" src="/preview/@SiteId?v=@_previewNonce"></iframe>
                </div>
            </div>
        </div>
    }

    <div class="canvas">
        <p class="tip">Click any text to edit it. Your changes save on their own.</p>

        @if (_undoLabel is not null)
        {
            <div class="undo" role="status">
                <span>@_undoLabel</span>
                <button type="button" @onclick="Undo">Undo</button>
            </div>
        }

        @for (var i = 0; i < _site.Draft.Sections.Count; i++)
        {
            var index = i;
            var section = _site.Draft.Sections[index];
            <section class="block">
                <div class="block-tools">
                    @if (_assistant is not null)
                    {
                        <button type="button" class="ai" title="Ask AI" @onclick="() => OpenAi(index)">✨</button>
                    }
                    <button type="button" title="Move up" disabled="@(index == 0)" @onclick="() => Move(index, -1)">↑</button>
                    <button type="button" title="Move down" disabled="@(index == _site.Draft.Sections.Count - 1)" @onclick="() => Move(index, 1)">↓</button>
                    <button type="button" class="danger" title="Remove" @onclick="() => Delete(index)">✕</button>
                </div>
                @switch (section)
                {
                    case HeroSection hero:
                        <input class="edit h1" @bind="hero.Headline" @bind:event="oninput" @bind:after="MarkDirty" placeholder="Your headline" />
                        <textarea class="edit lead" rows="2" @bind="hero.Subheadline" @bind:event="oninput" @bind:after="MarkDirty" placeholder="A supporting line"></textarea>
                        <input class="edit button" @bind="hero.CallToActionLabel" @bind:event="oninput" @bind:after="MarkDirty" placeholder="Button text" />
                        break;

                    case AboutSection about:
                        <input class="edit h2" @bind="about.Heading" @bind:event="oninput" @bind:after="MarkDirty" placeholder="About heading" />
                        <textarea class="edit body" rows="4" @bind="about.Body" @bind:event="oninput" @bind:after="MarkDirty" placeholder="Tell customers about your business"></textarea>
                        break;

                    case ServicesSection services:
                        <input class="edit h2" @bind="services.Heading" @bind:event="oninput" @bind:after="MarkDirty" placeholder="Services heading" />
                        @foreach (var item in services.Items)
                        {
                            <div class="item">
                                <input class="edit h3" @bind="item.Title" @bind:event="oninput" @bind:after="MarkDirty" placeholder="Service name" />
                                <textarea class="edit body" rows="2" @bind="item.Description" @bind:event="oninput" @bind:after="MarkDirty" placeholder="What it is"></textarea>
                                <input class="edit small" @bind="item.PriceLabel" @bind:event="oninput" @bind:after="MarkDirty" placeholder="Price (optional)" />
                            </div>
                        }
                        break;

                    case TestimonialsSection testimonials:
                        <input class="edit h2" @bind="testimonials.Heading" @bind:event="oninput" @bind:after="MarkDirty" placeholder="Reviews heading" />
                        @foreach (var quote in testimonials.Items)
                        {
                            <div class="item">
                                <textarea class="edit body" rows="2" @bind="quote.Quote" @bind:event="oninput" @bind:after="MarkDirty" placeholder="What they said"></textarea>
                                <input class="edit small" @bind="quote.AuthorName" @bind:event="oninput" @bind:after="MarkDirty" placeholder="Who said it" />
                            </div>
                        }
                        break;

                    case GallerySection gallery:
                        <input class="edit h2" @bind="gallery.Heading" @bind:event="oninput" @bind:after="MarkDirty" placeholder="Gallery heading" />
                        <p class="muted">Photos can be added from the Business details page (uploads are coming soon).</p>
                        break;

                    case ContactSection contact:
                        <input class="edit h2" @bind="contact.Heading" @bind:event="oninput" @bind:after="MarkDirty" placeholder="Contact heading" />
                        <p class="muted">Phone, WhatsApp and email are edited on the Business details page so they stay correct everywhere.</p>
                        break;

                    case HoursMapSection hoursMap:
                        <input class="edit h2" @bind="hoursMap.Heading" @bind:event="oninput" @bind:after="MarkDirty" placeholder="Find-us heading" />
                        <p class="muted">Address and opening hours are edited on the Business details page.</p>
                        break;

                    case CtaSection cta:
                        <input class="edit h2" @bind="cta.Headline" @bind:event="oninput" @bind:after="MarkDirty" placeholder="Closing line" />
                        <input class="edit button" @bind="cta.ButtonLabel" @bind:event="oninput" @bind:after="MarkDirty" placeholder="Button text" />
                        break;
                }

                @if (_aiIndex == index)
                {
                    <div class="ai-panel">
                        <input class="ai-input" @bind="_aiText" @bind:event="oninput"
                               placeholder="Tell the assistant what to change — e.g. &quot;make this friendlier&quot;" disabled="@_aiBusy" />
                        <div class="ai-actions">
                            <button type="button" @onclick="() => CloseAi()" disabled="@_aiBusy">Cancel</button>
                            <button type="button" class="go" @onclick="() => RunAi(index)" disabled="@_aiBusy">
                                @(_aiBusy ? "Working…" : "Update")
                            </button>
                        </div>
                        @if (_aiError is not null)
                        {
                            <p class="ai-error" role="alert">@_aiError</p>
                        }
                    </div>
                }
            </section>
        }

        <div class="add">
            @if (_showPicker)
            {
                <div class="picker">
                    <div class="picker-head">
                        <span>Add a section</span>
                        <button type="button" @onclick="() => _showPicker = false">Close</button>
                    </div>
                    <div class="picker-grid">
                        @foreach (var entry in SectionCatalog.Entries)
                        {
                            <button type="button" class="picker-item" @onclick="() => AddSection(entry)">
                                <strong>@entry.Label</strong>
                                <span>@entry.Description</span>
                            </button>
                        }
                    </div>
                </div>
            }
            else
            {
                <button type="button" class="add-btn" @onclick="() => _showPicker = true">+ Add a section</button>
            }
        </div>
    </div>
}

@code {
    [Parameter] public Guid SiteId { get; set; }

    private Core.Entities.Site? _site;
    private bool _notFound;
    private string _status = "Saved";
    private bool _dirty;
    private bool _publishing;
    private bool _showPreview;
    private bool _phoneWidth;
    private int _previewNonce;
    private bool _showPicker;
    private bool _showThemes = true;
    private string? _undoLabel;
    private Action? _undoAction;
    private CancellationTokenSource? _debounce;

    private ISectionAssistant? _assistant;
    private int? _aiIndex;
    private string _aiText = "";
    private string? _aiError;
    private bool _aiBusy;

    protected override async Task OnInitializedAsync()
    {
        _assistant = Services.GetService<ISectionAssistant>();

        var managed = await Management.LoadAsync(SiteId);
        if (managed is null)
        {
            _notFound = true;
            return;
        }

        _site = managed.Site;
    }

    private void OpenAi(int index)
    {
        _aiIndex = index;
        _aiText = "";
        _aiError = null;
    }

    private void CloseAi()
    {
        _aiIndex = null;
        _aiError = null;
    }

    private async Task RunAi(int index)
    {
        if (_assistant is null || string.IsNullOrWhiteSpace(_aiText))
        {
            return;
        }

        if (!RateLimiter.TryAcquire(_site!.TenantId))
        {
            _aiError = "You've reached today's AI edits. Try again tomorrow.";
            return;
        }

        _aiBusy = true;
        _aiError = null;
        try
        {
            var original = _site.Draft.Sections[index];
            var revised = await _assistant.ReviseAsync(original, _aiText);
            _site.Draft.Sections[index] = revised;

            _undoLabel = "The assistant updated this section.";
            _undoAction = () => _site.Draft.Sections[index] = original;
            _aiIndex = null;
            _aiText = "";
            MarkDirty();
        }
        catch (Exception)
        {
            _aiError = "The assistant couldn't make that change. Please try rewording it.";
        }
        finally
        {
            _aiBusy = false;
        }
    }

    private void Move(int index, int delta)
    {
        var sections = _site!.Draft.Sections;
        var target = index + delta;
        if (target < 0 || target >= sections.Count)
        {
            return;
        }

        (sections[index], sections[target]) = (sections[target], sections[index]);
        MarkDirty();
    }

    private void Delete(int index)
    {
        var sections = _site!.Draft.Sections;
        var section = sections[index];
        sections.RemoveAt(index);

        _undoLabel = "Section removed.";
        _undoAction = () => sections.Insert(Math.Min(index, sections.Count), section);
        MarkDirty();
    }

    private void Undo()
    {
        _undoAction?.Invoke();
        _undoAction = null;
        _undoLabel = null;
        MarkDirty();
    }

    private void AddSection(SectionCatalogEntry entry)
    {
        _site!.Draft.Sections.Add(entry.Create());
        _showPicker = false;
        _undoLabel = null;
        _undoAction = null;
        MarkDirty();
    }

    private bool IsCurrent(ThemePreset preset) =>
        _site is not null && string.Equals(_site.Draft.Theme.Palette.Primary, preset.Theme.Palette.Primary, StringComparison.OrdinalIgnoreCase);

    /// <summary>Applies a curated look. Only the theme changes — every word of copy is preserved.</summary>
    private void ApplyTheme(ThemePreset preset)
    {
        var previous = _site!.Draft.Theme;
        _site.Draft.Theme = preset.Theme.Clone();

        _undoLabel = $"Look changed to {preset.Label}.";
        _undoAction = () => _site.Draft.Theme = previous;
        _showThemes = false;
        MarkDirty();
    }

    private void TryAnotherLook()
    {
        var current = _site!.Draft.Theme.Palette.Primary;
        var others = ThemePresetCatalog.Presets
            .Where(p => !string.Equals(p.Theme.Palette.Primary, current, StringComparison.OrdinalIgnoreCase))
            .ToList();

        if (others.Count == 0)
        {
            return;
        }

        ApplyTheme(others[Random.Shared.Next(others.Count)]);
    }

    /// <summary>Every keystroke or structural change marks the draft dirty and (re)arms a short debounce.</summary>
    private void MarkDirty()
    {
        _dirty = true;
        _status = "Editing…";

        _debounce?.Cancel();
        _debounce?.Dispose();
        _debounce = new CancellationTokenSource();
        _ = SaveAfterPauseAsync(_debounce.Token);
    }

    private async Task SaveAfterPauseAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(1200, token);
        }
        catch (TaskCanceledException)
        {
            return; // A newer edit arrived; that one will save.
        }

        await SaveAsync();
    }

    private async Task SaveAsync()
    {
        if (!_dirty)
        {
            return;
        }

        _status = "Saving…";
        await InvokeAsync(StateHasChanged);

        try
        {
            await Management.SaveDraftAsync();
            _dirty = false;
            _status = "Saved";
        }
        catch (Exception)
        {
            // Leave it dirty so the next edit (or the next debounce) retries.
            _status = "Couldn't save — will retry";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenPreview()
    {
        // Save first so the preview reflects the latest edits; the nonce busts the iframe cache.
        await SaveAsync();
        _previewNonce++;
        _showPreview = true;
    }

    private async Task RefreshPreview()
    {
        await SaveAsync();
        _previewNonce++;
    }

    private async Task Publish()
    {
        _publishing = true;
        try
        {
            await SaveAsync();
            await Management.PublishAsync(SiteId);
            _status = "Published — your changes are live";
        }
        catch (Exception)
        {
            _status = "Couldn't publish — please try again";
        }
        finally
        {
            _publishing = false;
        }
    }

    public void Dispose()
    {
        _debounce?.Cancel();
        _debounce?.Dispose();
    }
}

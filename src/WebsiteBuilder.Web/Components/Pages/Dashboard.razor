    private record Stat(string Label, string Value, string Icon, string Note, bool Accent = false);
    private record Lead(string Initials, string Name, string Message, string Via, string Icon, string Time, bool Unread);
    private record SetupTask(string Label, bool Done);

    private static readonly NavItem[] Nav =
    {
        new("layout-dashboard", "Overview", "/dashboard", Active: true),

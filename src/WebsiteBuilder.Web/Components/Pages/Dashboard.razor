@page "/dashboard"

<PageTitle>Your dashboard — Sitely</PageTitle>

@* NOTE: presentational only. Leads, visitor stats and sign-in have no backend yet (WB-5 / WB-15);
   the numbers and rows below are illustrative sample data. *@

<div class="dash">
    <aside class="sidebar">
        <a class="side-brand" href="/">
            <span class="side-mark">@Icon("layout-template")</span>
            <span class="side-word">Sitely</span>
        </a>

        <nav class="side-nav">
            @foreach (var item in Nav)
            {
                <a class="nav-item @(item.Active ? "active" : "")" href="@item.Href">
                    <span class="nav-ico">@Icon(item.Icon)</span>
                    <span class="nav-label">@item.Label</span>
                    @if (item.Badge is not null)
                    {
                        <span class="nav-badge">@item.Badge</span>
                    }
                </a>
            }
        </nav>

        <div class="side-spacer"></div>

        <div class="upgrade">
            <div class="upgrade-t">You're on the free plan</div>
            <div class="upgrade-s">Connect your own domain and remove the Sitely badge.</div>
            <a class="upgrade-btn" href="#">Upgrade</a>
        </div>
        <div class="profile">
            <span class="profile-av">K</span>
            <span class="profile-txt">
                <span class="profile-name">Kwame O.</span>
                <span class="profile-biz">Rapid Flow Plumbing</span>
            </span>
        </div>
    </aside>

    <main class="main">
        <header class="head">
            <div class="head-left">
                <h1>Good morning, Kwame</h1>
                <p>Here's how your website is doing this week.</p>
            </div>
            <div class="head-right">
                <a class="btn ghost" href="#">@Icon("external-link") View site</a>
                <a class="btn solid" href="#">@Icon("pencil") Edit site</a>
            </div>
        </header>

        <section class="status-card">
            <div class="status-left">
                <span class="status-dot">@Icon("check")</span>
                <div class="status-info">
                    <div class="status-row">
                        <span class="status-title">Your site is live</span>
                        <span class="status-pill"><i></i>Published</span>
                    </div>
                    <div class="status-url">
                        @Icon("globe")
                        <span>rapidflow.sitely.site</span>
                        <span class="status-updated">·&nbsp; Updated 2 hours ago</span>
                    </div>
                </div>
            </div>
            <a class="domain-btn" href="#">@Icon("link") Connect custom domain</a>
        </section>

        <section class="stats">
            @foreach (var s in Stats)
            {
                <div class="stat">
                    <div class="stat-top">
                        <span class="stat-label">@s.Label</span>
                        <span class="stat-ico">@Icon(s.Icon)</span>
                    </div>
                    <div class="stat-value">@s.Value</div>
                    <div class="stat-note @(s.Accent ? "up" : "")">@s.Note</div>
                </div>
            }
        </section>

        <section class="bottom">
            <div class="leads-card">
                <div class="leads-head">
                    <div class="leads-title">
                        <span>Recent leads</span>
                        <span class="new-badge">3 new</span>
                    </div>
                    <a class="view-all" href="#">View all</a>
                </div>
                <div class="table">
                    @foreach (var lead in Leads)
                    {
                        <div class="lead @(lead.Unread ? "unread" : "")">
                            <span class="lead-av">@lead.Initials</span>
                            <div class="lead-mid">
                                <div class="lead-name-row">
                                    <span class="lead-name">@lead.Name</span>
                                    @if (lead.Unread)
                                    {
                                        <span class="lead-unread"></span>
                                    }
                                </div>
                                <div class="lead-msg">@lead.Message</div>
                            </div>
                            <div class="lead-meta">
                                <span class="lead-via">@Icon(lead.Icon) @lead.Via</span>
                                <span class="lead-time">@lead.Time</span>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="side-col">
                <div class="setup-card">
                    <div class="setup-head">
                        <span class="setup-title">Finish setting up</span>
                        <span class="setup-sub">3 of 5 done — you're almost there.</span>
                    </div>
                    <div class="setup-track"><span></span></div>
                    <div class="tasks">
                        @foreach (var task in SetupTasks)
                        {
                            <div class="task">
                                <span class="task-cb @(task.Done ? "done" : "")">@(task.Done ? Icon("check") : default)</span>
                                <span class="task-label @(task.Done ? "done" : "")">@task.Label</span>
                                @if (!task.Done)
                                {
                                    <span class="task-arrow">@Icon("chevron-right")</span>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="tip-card">
                    <span class="tip-ico">@Icon("lightbulb")</span>
                    <div class="tip-title">Reply to leads within an hour</div>
                    <div class="tip-body">Businesses that respond quickly win up to 7× more jobs. We'll email you the moment a new lead comes in.</div>
                    <a class="tip-btn" href="#">@Icon("bell") Notification settings</a>
                </div>
            </div>
        </section>
    </main>
</div>

@code {

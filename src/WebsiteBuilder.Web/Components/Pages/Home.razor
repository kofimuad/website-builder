@page "/"

<PageTitle>Sitely — Websites for small businesses</PageTitle>

<div class="home">

    <header class="nav">
        <a class="brand" href="/">
            <span class="brand-mark">@Icon("layout-template")</span>
            <span class="brand-name">Sitely</span>
        </a>
        <nav class="nav-right">
            <div class="nav-links">
                <a href="#templates">Templates</a>
                <a href="#how">How it works</a>
                <a href="#pricing">Pricing</a>
            </div>
            <a class="nav-signin" href="/start">Sign in</a>
            <a class="btn btn-primary btn-pill" href="/start">Start free</a>
        </nav>
    </header>

    <section class="hero">
        <div class="hero-left">
            <span class="eyebrow">Websites for small businesses</span>
            <h1 class="hero-headline">Your business deserves a website. You'll have one by lunch.</h1>
            <p class="hero-subcopy">Answer a few plain questions and we build your site for you. Change any word or photo by tapping it — no design skills, no code, nothing to install.</p>
            <div class="hero-cta">
                <a class="btn btn-primary btn-lg" href="/start">Start free</a>
                <a class="btn btn-outline btn-lg" href="#example">See a live example @Icon("arrow-up-right")</a>
            </div>
            <div class="hero-trust">
                <span class="trust-check">@Icon("circle-check")</span>
                <span>No credit card · Live in under 10 minutes</span>
            </div>
        </div>

        <div class="hero-tile">
            <div class="phone">
                <div class="phone-screen">
                    <div class="site-hero">
                        <div class="site-biz">JOE'S PLUMBING</div>
                        <div class="site-headline">Blocked drain? We come today.</div>
                        <div class="site-sub">Family-run plumbers serving Accra since 1998.</div>
                        <div class="site-call">Call now</div>
                    </div>
                    <div class="site-services">
                        <div class="site-svhead">What we do</div>
                        <div class="site-svcard">
                            <div class="site-svtitle">Drain clearing</div>
                            <div class="site-svdesc">Cleared fast, no mess left behind.</div>
                        </div>
                        <div class="site-svcard">
                            <div class="site-svtitle">Leak detection</div>
                            <div class="site-svdesc">Found and fixed the same visit.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="proof">
        <div class="section-head">
            <span class="eyebrow">How it feels</span>
            <h2 class="section-title">Building a website, minus the hard part</h2>
        </div>
        <div class="proof-cluster">
            <div class="proof-big">
                <div class="proof-big-top">
                    <span class="step-pill">YOU ANSWER</span>
                    <h3 class="proof-big-h">Just answer a few plain questions about your business</h3>
                    <p class="proof-big-sub">No jargon. "What should customers do — call you, visit, or book?" That's the level.</p>
                </div>
                <div class="qcard">
                    <div class="qcard-q">What should customers do first?</div>
                    <div class="qcard-chips">
                        <span class="chip chip-active">Call you</span>
                        <span class="chip">Visit</span>
                        <span class="chip">Book</span>
                    </div>
                </div>
            </div>
            <div class="proof-right">
                <div class="feature-card">
                    <div class="feature-row">
                        <span class="feature-ib">@Icon("sparkles")</span>
                        <span class="feature-h">We write your words</span>
                    </div>
                    <p class="feature-d">Real copy in your voice — headlines, about, services. Not lorem ipsum.</p>
                    <div class="feature-demo">
                        <span class="skel" style="width:210px"></span>
                        <span class="skel" style="width:250px"></span>
                        <span class="skel" style="width:170px"></span>
                    </div>
                </div>
                <div class="feature-card">
                    <div class="feature-row">
                        <span class="feature-ib">@Icon("mouse-pointer-click")</span>
                        <span class="feature-h">Tap to change anything</span>
                    </div>
                    <p class="feature-d">See a word you'd say differently? Tap it and type. It saves on its own.</p>
                    <div class="feature-demo">
                        <div class="edit-field">
                            <span class="edit-text">Blocked drain? We come today</span>
                            <span class="edit-cursor"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="how" id="how">
        <div class="section-head">
            <span class="eyebrow">How it works</span>
            <h2 class="section-title">Three steps. That's the whole thing.</h2>
        </div>
        <div class="steps">
            @foreach (var step in Steps)
            {
                <div class="step">
                    <div class="step-badge">@step.Number</div>
                    <h3 class="step-h">@step.Title</h3>
                    <p class="step-d">@step.Desc</p>
                </div>
            }
        </div>
    </section>

    <section class="templates" id="templates">
        <div class="section-head">
            <span class="eyebrow">Templates</span>
            <h2 class="section-title">Made for your kind of business</h2>
            <p class="section-sub">Start from a design built for your trade — or let us pick the right one for you.</p>
        </div>
        <div class="template-grid">
            @foreach (var t in Templates)
            {
                <div class="template-card">
                    <div class="template-band" style="background:@t.Color">
                        <span class="band-bar-a"></span>
                        <span class="band-bar-b"></span>
                        <span class="band-pill"><span class="band-pill-bar" style="background:@t.Color"></span></span>
                    </div>
                    <div class="template-body">
                        <div class="template-title">@t.Title</div>
                        <div class="template-desc">@t.Desc</div>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="credibility">
        <div class="section-head">
            <h2 class="cred-title">A real website, not a toy page</h2>
            <p class="cred-sub">Everything a small business needs to look professional and get found — handled for you.</p>
        </div>
        <div class="cred-cols">
            @foreach (var f in Credibility)
            {
                <div class="cred-col">
                    <span class="cred-ib">@Icon(f.Icon)</span>
                    <h3 class="cred-h">@f.Title</h3>
                    <p class="cred-d">@f.Desc</p>
                </div>
            }
        </div>
    </section>

    <section class="final-cta" id="pricing">
        <div class="cta-tile">
            <h2 class="cta-h">Ready to get your business online?</h2>
            <p class="cta-sub">Free to start, no credit card. Your first site is minutes away.</p>
            <a class="btn btn-primary btn-xl" href="/start">Start free</a>
        </div>
    </section>

    <footer class="footer">
        <div class="footer-divider"></div>
        <div class="footer-row">
            <div class="footer-brand">
                <span class="footer-mark">@Icon("layout-template")</span>
                <span class="footer-name">Sitely</span>
            </div>
            <nav class="footer-links">
                <a href="#templates">Templates</a>
                <a href="#pricing">Pricing</a>
                <a href="#help">Help</a>
                <a href="#privacy">Privacy</a>
            </nav>
        </div>
        <div class="footer-copy">© 2026 Sitely. Websites for small businesses.</div>
    </footer>

</div>

@code {
    private record Step(string Number, string Title, string Desc);
    private record Template(string Title, string Desc, string Color);
    private record Feature(string Icon, string Title, string Desc);

    private static readonly Step[] Steps =
    {
        new("01", "Tell us about your business", "A few plain questions about what you do and how customers reach you."),
        new("02", "Get your site, written for you", "We build the pages and write the words. Ready to look at in about a minute."),
        new("03", "Make it yours, then publish", "Tap to edit anything, pick a look you love, and go live on your own web address."),
    };

    private static readonly Template[] Templates =
    {
        new("Restaurants & cafés", "Menus, hours, and a map", "#B26A2A"),
        new("Salons & barbers", "Services and easy booking", "#7A3A63"),
        new("Trades & home services", "Call-first, jobs up front", "#0A7D55"),
        new("Consultants", "Calm, credible, to the point", "#24406B"),
        new("Events & weddings", "Galleries that shine", "#9E2B50"),
        new("Churches & nonprofits", "Times, place, and giving", "#14746F"),
    };

    private static readonly Feature[] Credibility =
    {
        new("zap", "Fast on any phone", "Loads in under a second, even on slow data. Most of your customers are on a phone."),
        new("search", "Found on Google", "Clean, indexable pages with the right titles and descriptions — set up for you."),
        new("globe", "Your own web address", "yourbusiness.com, ready to share on cards, WhatsApp, and Instagram."),
    };

    private static readonly Dictionary<string, string> Icons = new()
    {
        ["layout-template"] = "<rect width='18' height='7' x='3' y='3' rx='1'/><rect width='9' height='7' x='3' y='14' rx='1'/><rect width='5' height='7' x='16' y='14' rx='1'/>",
        ["arrow-up-right"] = "<path d='M7 7h10v10'/><path d='M7 17 17 7'/>",
        ["circle-check"] = "<circle cx='12' cy='12' r='10'/><path d='m9 12 2 2 4-4'/>",
        ["sparkles"] = "<path d='M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z'/><path d='M20 3v4'/><path d='M22 5h-4'/><path d='M4 17v2'/><path d='M5 18H3'/>",
        ["mouse-pointer-click"] = "<path d='m9 9 5 12 1.8-5.2L21 14Z'/><path d='M7.2 2.2 8 5.1'/><path d='m5.1 8-2.9-.8'/><path d='M14 4.1 12 6'/><path d='m6 12-1.9 2'/>",
        ["zap"] = "<path d='M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z'/>",
        ["search"] = "<circle cx='11' cy='11' r='8'/><path d='m21 21-4.3-4.3'/>",
        ["globe"] = "<circle cx='12' cy='12' r='10'/><path d='M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20'/><path d='M2 12h20'/>",
    };

    private static MarkupString Icon(string name) => new(
        $"<svg class='icon' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>{Icons[name]}</svg>");
}

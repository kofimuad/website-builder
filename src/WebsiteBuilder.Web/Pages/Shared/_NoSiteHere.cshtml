@* Shown when a host resolves to no tenant, or to a tenant with nothing published yet. *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Site not found</title>
    <style>
        :root { color-scheme: light dark; }
        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 1.5rem;
            font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
            line-height: 1.6;
            background: #fbfbfd;
            color: #1d1d21;
        }
        main { max-width: 32rem; text-align: center; }
        h1 { font-size: 1.5rem; margin: 0 0 .75rem; }
        p { margin: 0; color: #55555f; }
        @@media (prefers-color-scheme: dark) {
            body { background: #131316; color: #f2f2f5; }
            p { color: #a5a5b0; }
        }
    </style>
</head>
<body>
    <main>
        <h1>There's no website here yet</h1>
        <p>
            This address isn't connected to a published site. If you typed it in,
            double-check the spelling &mdash; otherwise the owner may not have published yet.
        </p>
    </main>
</body>
</html>

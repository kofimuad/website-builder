@page "/site"
@using WebsiteBuilder.Core.SiteModel
@model WebsiteBuilder.Web.Pages.SiteModel
@{
    Layout = null;
}
@if (Model.Definition is null)
{
    @await Html.PartialAsync("_NoSiteHere")
    return;
}
@{
    var site = Model.Definition;
    var theme = site.Theme;
    var title = string.IsNullOrWhiteSpace(site.Meta.SeoTitle) ? site.Meta.BusinessName : site.Meta.SeoTitle;
    var description = site.Meta.SeoDescription ?? site.Meta.Tagline;
    var visible = site.Sections.Where(s => s.Visible).ToList();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>
    @if (!string.IsNullOrWhiteSpace(description))
    {
        <meta name="description" content="@description" />
    }
    @* Styles are inlined: a published site is one document with no blocking requests. *@
    <style>
        :root {
            --primary: @theme.Palette.Primary;
            --accent: @theme.Palette.Accent;
            --background: @theme.Palette.Background;
            --surface: @theme.Palette.Surface;
            --text: @theme.Palette.Text;
            --muted: @theme.Palette.MutedText;
            --font-heading: "@theme.Fonts.Heading", system-ui, sans-serif;
            --font-body: "@theme.Fonts.Body", system-ui, sans-serif;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: var(--font-body);
            color: var(--text);
            background: var(--background);
            line-height: 1.6;
        }
        h1, h2, h3 { font-family: var(--font-heading); line-height: 1.2; margin: 0 0 .5em; }
        img { max-width: 100%; height: auto; display: block; }
        a { color: var(--primary); }
        section, header { padding: 3rem 1.25rem; }
        section:nth-of-type(even) { background: var(--surface); }
        .wrap { max-width: 60rem; margin: 0 auto; }
        .hero { background: var(--surface); text-align: center; }
        .hero h1 { font-size: clamp(1.75rem, 6vw, 3rem); }
        .hero p { color: var(--muted); font-size: 1.125rem; max-width: 40rem; margin-inline: auto; }
        .button {
            display: inline-block;
            margin-top: 1.25rem;
            padding: .75rem 1.5rem;
            border-radius: .5rem;
            background: var(--primary);
            color: #fff;
            text-decoration: none;
            font-weight: 600;
        }
        .grid { display: grid; gap: 1.25rem; grid-template-columns: 1fr; }
        .card { background: var(--background); border-radius: .75rem; padding: 1.25rem; }
        .price { color: var(--muted); font-weight: 600; }
        blockquote { margin: 0; padding: 1.25rem; background: var(--background); border-radius: .75rem; }
        blockquote cite { display: block; margin-top: .75rem; color: var(--muted); font-style: normal; }
        .contact-links { list-style: none; padding: 0; display: grid; gap: .5rem; }
        table { border-collapse: collapse; width: 100%; max-width: 24rem; }
        td { padding: .25rem 0; }
        td + td { text-align: right; color: var(--muted); }
        iframe { width: 100%; border: 0; aspect-ratio: 16 / 9; margin-top: 1.5rem; border-radius: .75rem; }
        /* Mobile first: widen only once there is room. */
        @@media (min-width: 40rem) {
            section, header { padding: 4rem 2rem; }
            .grid { grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); }
        }
    </style>
</head>
<body>
@foreach (var section in visible)
{
    switch (section)
    {
        case HeroSection hero:
            <header class="hero">
                <div class="wrap">
                    <h1>@hero.Headline</h1>
                    @if (!string.IsNullOrWhiteSpace(hero.Subheadline))
                    {
                        <p>@hero.Subheadline</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(hero.CallToActionLabel) && !string.IsNullOrWhiteSpace(hero.CallToActionUrl))
                    {
                        <a class="button" href="@hero.CallToActionUrl">@hero.CallToActionLabel</a>
                    }
                    @if (!string.IsNullOrWhiteSpace(hero.ImageUrl))
                    {
                        <img src="@hero.ImageUrl" alt="" loading="lazy" />
                    }
                </div>
            </header>
            break;

        case AboutSection about:
            <section>
                <div class="wrap">
                    <h2>@about.Heading</h2>
                    @foreach (var paragraph in about.Body.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                    {
                        <p>@paragraph</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(about.ImageUrl))
                    {
                        <img src="@about.ImageUrl" alt="" loading="lazy" />
                    }
                </div>
            </section>
            break;

        case ServicesSection services:
            <section>
                <div class="wrap">
                    <h2>@services.Heading</h2>
                    <div class="grid">
                        @foreach (var item in services.Items)
                        {
                            <div class="card">
                                <h3>@item.Title</h3>
                                <p>@item.Description</p>
                                @if (!string.IsNullOrWhiteSpace(item.PriceLabel))
                                {
                                    <p class="price">@item.PriceLabel</p>
                                }
                            </div>
                        }
                    </div>
                </div>
            </section>
            break;

        case GallerySection gallery:
            <section>
                <div class="wrap">
                    <h2>@gallery.Heading</h2>
                    <div class="grid">
                        @foreach (var image in gallery.Images)
                        {
                            <figure style="margin:0">
                                <img src="@image.Url" alt="@image.AltText" loading="lazy" />
                                @if (!string.IsNullOrWhiteSpace(image.Caption))
                                {
                                    <figcaption class="price">@image.Caption</figcaption>
                                }
                            </figure>
                        }
                    </div>
                </div>
            </section>
            break;

        case TestimonialsSection testimonials:
            <section>
                <div class="wrap">
                    <h2>@testimonials.Heading</h2>
                    <div class="grid">
                        @foreach (var testimonial in testimonials.Items)
                        {
                            <blockquote>
                                <p>@testimonial.Quote</p>
                                <cite>@testimonial.AuthorName@(string.IsNullOrWhiteSpace(testimonial.AuthorDetail) ? "" : $", {testimonial.AuthorDetail}")</cite>
                            </blockquote>
                        }
                    </div>
                </div>
            </section>
            break;

        case ContactSection contact:
            <section>
                <div class="wrap">
                    <h2>@contact.Heading</h2>
                    @* The enquiry form itself is WB-5; direct contact works without it. *@
                    <ul class="contact-links">
                        @if (!string.IsNullOrWhiteSpace(contact.PhoneNumber))
                        {
                            <li><a href="tel:@contact.PhoneNumber">Call @contact.PhoneNumber</a></li>
                        }
                        @if (!string.IsNullOrWhiteSpace(contact.WhatsAppNumber))
                        {
                            <li><a href="https://wa.me/@contact.WhatsAppNumber.TrimStart('+')">Message on WhatsApp</a></li>
                        }
                        @if (!string.IsNullOrWhiteSpace(contact.Email))
                        {
                            <li><a href="mailto:@contact.Email">@contact.Email</a></li>
                        }
                    </ul>
                </div>
            </section>
            break;

        case HoursMapSection hoursMap:
            <section>
                <div class="wrap">
                    <h2>@hoursMap.Heading</h2>
                    @if (hoursMap.AddressLines.Count > 0)
                    {
                        <address>
                            @foreach (var line in hoursMap.AddressLines)
                            {
                                @line<br />
                            }
                        </address>
                    }
                    @if (hoursMap.OpeningHours.Count > 0)
                    {
                        <table>
                            <tbody>
                            @foreach (var hours in hoursMap.OpeningHours)
                            {
                                <tr>
                                    <td>@hours.Day</td>
                                    <td>
                                        @if (hours.Closed || hours.Opens is null || hours.Closes is null)
                                        {
                                            @:Closed
                                        }
                                        else
                                        {
                                            @($"{hours.Opens:HH\\:mm} – {hours.Closes:HH\\:mm}")
                                        }
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    }
                    @if (!string.IsNullOrWhiteSpace(hoursMap.MapQuery))
                    {
                        <iframe title="Map" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
                                src="https://maps.google.com/maps?q=@Uri.EscapeDataString(hoursMap.MapQuery)&output=embed"></iframe>
                    }
                </div>
            </section>
            break;

        case CtaSection cta:
            <section>
                <div class="wrap" style="text-align:center">
                    <h2>@cta.Headline</h2>
                    <a class="button" href="@cta.ButtonUrl">@cta.ButtonLabel</a>
                </div>
            </section>
            break;
    }
}
</body>
</html>
